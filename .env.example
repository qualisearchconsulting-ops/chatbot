# ============================================
# Facebook Messenger Webhook Configuration
# ============================================

# Your Facebook App's Page Access Token
# Get this from: Meta Developers > Your App > Messenger > API Settings
PAGE_ACCESS_TOKEN=your_page_access_token_here

# The Verify Token you entered in the Facebook Webhook settings
# Must match EXACTLY what you typed in the "Verify token" field on Meta
VERIFY_TOKEN=your_verify_token_here

# Set to false to disable every automated reply until the service restarts.
CHATBOT_ENABLED=true

# A manual reply from Meta Business Suite pauses the bot for this many minutes.
HUMAN_HANDOFF_MINUTES=30

# Password used to open the web control page. Use a long, random secret.
CHATBOT_ADMIN_TOKEN=replace_with_a_long_random_secret

# APP_SECRET is OPTIONAL — enables HMAC-SHA256 signature verification
# Get from: Meta Developers → Your App → Settings → Basic → App Secret
# APP_SECRET=your_app_secret_here

# ============================================
# Server Configuration
# ============================================
PORT=3000
NODE_ENV=development

# ============================================
# Optional: QualiSearch API Integration
# ============================================
QUALISEARCH_API_URL=https://api.qualisearch.com
QUALISEARCH_API_KEY=your_qualisearch_api_key_here

# ============================================
# Groq AI Fallback (optional)
# Used only when keyword matching fails — not required for basic operation.
# Get your key from: https://console.groq.com/
# ============================================
Groq_API=your_groq_api_key_here
