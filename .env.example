# ============================================
# Facebook Messenger Webhook Configuration
# ============================================

# Your Facebook App's Page Access Token
# Get this from: Meta Developers > Your App > Messenger > API Settings
PAGE_ACCESS_TOKEN=your_page_access_token_here

# The Verify Token you entered in the Facebook Webhook settings
# Must match EXACTLY what you typed in the "Verify token" field on Meta
VERIFY_TOKEN=your_verify_token_here

# Your Facebook App Secret (used to validate incoming webhook signatures)
# Get this from: Meta Developers > Your App > Settings > Basic
APP_SECRET=your_app_secret_here

# ============================================
# Server Configuration
# ============================================
PORT=3000
NODE_ENV=development

# ============================================
# Optional: QualiSearch API Integration
# ============================================
QUALISEARCH_API_URL=https://api.qualisearch.com
QUALISEARCH_API_KEY=your_qualisearch_api_key_here
